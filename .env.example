# .env.example
# Copy this to .env.local and fill in all values before running locally.
# Add all of these to your Vercel project settings for production.

# ── DATABASE (Supabase PostgreSQL) ────────────────────────────────────────────
# Found in: Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ── SUPABASE ─────────────────────────────────────────────────────────────────
# Found in: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# ── SITE URL ──────────────────────────────────────────────────────────────────
# Your full domain (no trailing slash) — used for redirects, invite links, etc.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── RESEND (transactional email) ──────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY="re_your_api_key_here"
# The "from" address — must match a verified domain in Resend
EMAIL_FROM="noreply@yourdomain.com"

# ── SUPER ADMIN SEED ──────────────────────────────────────────────────────────
# Used only during `npm run prisma:seed` — change immediately after first login
SUPER_ADMIN_EMAIL="admin@yourdomain.com"
SUPER_ADMIN_PASSWORD="ChangeMe123!"
